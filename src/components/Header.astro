---
const navItems = [
  { label: 'How It Works', href: '#how-it-works' },
  { label: 'Pricing', href: '#pricing' },
  { label: 'FAQ', href: '#faq' },
];
---

<header class="fixed top-0 left-0 right-0 z-50 bg-surface-0/90 backdrop-blur-md border-b border-surface-3/50">
  <nav class="container-wide flex items-center justify-between h-16">
    <a href="/" class="flex items-center gap-2 no-underline group">
      <div class="w-8 h-8 rounded-lg bg-accent/10 border border-accent/20 flex items-center justify-center">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent">
          <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
          <polyline points="9 12 11 14 15 10"/>
        </svg>
      </div>
      <span class="text-md font-semibold text-ink-primary">SureShift</span>
    </a>

    <div class="hidden md:flex items-center gap-8">
      {navItems.map(item => (
        <a href={item.href} class="text-sm text-ink-secondary hover:text-ink-primary no-underline transition-colors">
          {item.label}
        </a>
      ))}
      <a href="#run-scan" class="btn-primary text-sm !py-2 !px-4">
        Run Free Scan
      </a>
    </div>

    <!-- Mobile menu button -->
    <button
      id="mobile-menu-btn"
      class="md:hidden p-2 text-ink-secondary hover:text-ink-primary"
      aria-label="Toggle menu"
    >
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <line x1="3" y1="6" x2="21" y2="6"/>
        <line x1="3" y1="12" x2="21" y2="12"/>
        <line x1="3" y1="18" x2="21" y2="18"/>
      </svg>
    </button>
  </nav>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-surface-3 bg-surface-0 px-6 py-4">
    {navItems.map(item => (
      <a href={item.href} class="block py-2 text-sm text-ink-secondary hover:text-ink-primary no-underline">
        {item.label}
      </a>
    ))}
    <a href="#run-scan" class="btn-primary text-sm !py-2 mt-3 w-full text-center">
      Run Free Scan
    </a>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>
