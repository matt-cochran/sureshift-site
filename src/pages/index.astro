<!-- ═══════════════════════════════════════════
     CLIENT-SIDE SCRIPTS
═══════════════════════════════════════════ -->
<script>
  // ── Scroll-triggered reveal animations (F5) ──
  const revealObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          revealObserver.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
  );

  document.querySelectorAll('.reveal, .reveal-stagger').forEach((el) => {
    revealObserver.observe(el);
  });

  // ── Terminal typing animation (F6) ──
  const terminalEl = document.getElementById('terminal-animated');
  if (terminalEl) {
    const terminalObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            terminalEl.classList.add('terminal-animated');
            terminalObserver.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.3 }
    );
    terminalObserver.observe(terminalEl);
  }

  // ── Install method tabs (F7) ──
  const installTabs = document.querySelectorAll('.install-tab');
  const installPanels = document.querySelectorAll('.install-panel');

  installTabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      const target = (tab as HTMLElement).dataset.tab;
      installTabs.forEach((t) => t.classList.remove('active'));
      installPanels.forEach((p) => p.classList.remove('active'));
      tab.classList.add('active');
      document.querySelector(`[data-panel="${target}"]`)?.classList.add('active');
    });
  });

  // ── Mobile sticky CTA (F14) ──
  const heroSection = document.querySelector('main > section:first-child');
  const stickyCta = document.getElementById('mobile-sticky-cta');
  const runScanSection = document.getElementById('run-scan');

  if (heroSection && stickyCta) {
    const stickyObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          // Show sticky CTA when hero is out of view
          if (!entry.isIntersecting) {
            stickyCta.classList.add('is-visible');
          } else {
            stickyCta.classList.remove('is-visible');
          }
        });
      },
      { threshold: 0 }
    );
    stickyObserver.observe(heroSection);

    // Hide when bottom CTA is visible
    if (runScanSection) {
      const bottomObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              stickyCta.classList.remove('is-visible');
            }
          });
        },
        { threshold: 0.3 }
      );
      bottomObserver.observe(runScanSection);
    }
  }

  // ── Compare plans toggle (F9) ──
  const compareBtn = document.getElementById('compare-plans-btn');
  const pricingExpanded = document.getElementById('pricing-expanded');
  const compareChevron = document.getElementById('compare-chevron');

  if (compareBtn && pricingExpanded) {
    compareBtn.addEventListener('click', () => {
      pricingExpanded.classList.toggle('is-open');
      compareChevron?.classList.toggle('rotate-180');
    });
  }
</script>
